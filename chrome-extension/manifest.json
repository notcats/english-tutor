{
  "manifest_version": 3,
  "name": "AI Dictionary",
  "version": "1.0.0",
  "description": "Select any word to translate & add to your AI Dictionary",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://7b0b.up.railway.app/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
